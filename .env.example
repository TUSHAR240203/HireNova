# Service Port Configurations
PORT=3000

# Database URIs
MONGODB_URI=mongodb://localhost:27017/hirenova
REDIS_URI=redis://localhost:6379

# Search & Messaging Services
OPENSEARCH_URL=http://localhost:9200
KAFKA_BROKERS=localhost:9092

# JWT & Authentication Secret Tokens
JWT_SECRET=super_secret_access_token_sign_key_change_me_in_production
JWT_REFRESH_SECRET=super_secret_refresh_token_sign_key_change_me_in_production
SESSION_SECRET=local_express_session_security_signing_passphrase

# Third-Party AI Integrations
OPENAI_API_KEY=your_openai_api_token_here

# Communication Gateways
SENDGRID_API_KEY=your_sendgrid_integration_api_key_here
AWS_SES_REGION=us-east-1

# Cloud Storage and CDN Parameters
AWS_ACCESS_KEY_ID=your_aws_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1
S3_BUCKET_NAME=hirenova-resumes-local
CLOUDFRONT_DOMAIN=your_cloudfront_distribution_id.cloudfront.net
AWS_WAF_ACL_ID=your_waf_arn_here
AWS_SECRETS_MANAGER_SECRET_NAME=hirenova-prod-secrets
